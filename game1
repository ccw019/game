<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>中文語法練習遊戲</title>
    <style>
        :root { --primary-color: #4a90e2; --error-color: #e74c3c; --success-color: #2ecc71; --bg-color: #f5f7fa; --card-bg: #ffffff; --text-color: #333; }
        body { font-family: sans-serif; background-color: var(--bg-color); color: var(--text-color); margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        #game-container { width: 100%; max-width: 500px; background: var(--card-bg); padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); text-align: center; }
        .progress-container { width: 100%; height: 10px; background: #e0e0e0; border-radius: 5px; margin-bottom: 20px; overflow: hidden; }
        #progress-bar { width: 0%; height: 100%; background: var(--primary-color); transition: width 0.3s ease; }
        #question-text { font-size: 1.4rem; line-height: 1.6; margin: 30px 0; min-height: 80px; }
        .option-btn { display: block; width: 100%; padding: 15px; margin-bottom: 10px; font-size: 1.2rem; background: #fff; border: 2px solid var(--primary-color); border-radius: 10px; color: var(--primary-color); cursor: pointer; }
        #result-screen { display: none; width: 100%; max-width: 500px; padding: 20px; background: white; border-radius: 15px; text-align: center; }
        .highlight-error { color: var(--error-color); font-weight: bold; text-decoration: underline; }
    </style>
</head>
<body>

    <div id="game-container">
        <div class="progress-container"><div id="progress-bar"></div></div>
        <div id="question-text">載入中...</div>
        <div id="options"></div>
    </div>

    <div id="result-screen">
        <h2>練習結束！</h2>
        <p id="final-score"></p>
        <button onclick="location.reload()">重新挑戰</button>
    </div>

    <script>
        const rawData = [
            { s: "他跟老師說的中文，你＿＿嗎？", o: ["聽懂了", "看了"], a: "聽懂了" },
            { s: "那些資料我得再看看，昨天我＿＿。", o: ["沒看懂", "聽懂了"], a: "沒看懂" },
            { s: "那個法國電影，你＿＿沒有？", o: ["看懂", "看得"], a: "看懂" },
            { s: "這份合約有點複雜，我看了好幾次才＿＿。", o: ["看懂", "聽懂了"], a: "看懂" },
            { s: "音樂太吵了，我＿＿。", o: ["聽不見", "聽懂了"], a: "聽不見" },
            { s: "那幾個外國人說的英文你＿＿嗎？", o: ["沒看懂", "聽得懂"], a: "聽得懂" },
            { s: "我學過幾年英文，他們說的我應該＿＿。", o: ["聽了", "聽得懂"], a: "聽得懂" },
            { s: "現在已經三點了，早上六點你＿＿嗎？", o: ["起得來", "想起來"], a: "起得來" },
            { s: "我好像在哪裡看過那位太極拳師父，可是我＿＿。", o: ["想起來", "想不起來"], a: "想不起來" },
            { s: "你的垃圾那麼多，桶子那麼小，＿＿嗎？", o: ["放得下", "聽得懂"], a: "放得下" },
            { s: "桌上的菜太多了，我＿＿。", o: ["吃不了", "拿不了"], a: "吃不了" },
            { s: "媽媽，你不需要給我那麼多錢，我＿＿。", o: ["夠用了", "拿不了"], a: "夠用了" },
            { s: "我們走路去學校，20分鐘＿＿嗎？", o: ["沒看懂", "到得了"], a: "到得了" },
            { s: "我的作業還沒做完，你們去吃飯吧，我＿＿。", o: ["走不了", "到得了"], a: "走不了" },
            { s: "天氣太熱了，＿＿我吃不下飯。", o: ["熱得", "走得"], a: "熱得" },
            { s: "老師說話＿＿太快了，大家都＿＿。", o: ["說得／聽不懂", "走得／聽不了"], a: "說得／聽不懂" },
            { s: "那間餐廳的菜好難吃，＿＿我都吃不下了。", o: ["難吃得", "吃了"], a: "難吃得" },
            { s: "你是不是＿＿走不了了。", o: ["累得", "走了"], a: "累得" },
            { s: "今天考試拿到一百分，我＿＿大叫。", o: ["高興得", "懂了"], a: "高興得" },
            { s: "東西那麼多，你＿＿嗎？", o: ["吃得了", "拿得了"], a: "拿得了" }
        ];

        let questions = [...rawData].sort(() => Math.random() - 0.5);
        let currentStep = 0, score = 0;

        function render() {
            if (currentStep >= 20) {
                document.getElementById('game-container').style.display = 'none';
                document.getElementById('result-screen').style.display = 'block';
                document.getElementById('final-score').innerText = `得分：${score} / 20`;
                return;
            }
            const q = questions[currentStep];
            document.getElementById('progress-bar').style.width = ((currentStep / 20) * 100) + '%';
            document.getElementById('question-text').innerHTML = q.s;
            const optDiv = document.getElementById('options');
            optDiv.innerHTML = '';
            q.o.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.innerText = opt;
                btn.onclick = () => {
                    if (opt === q.a) { score++; currentStep++; render(); }
                    else {
                        document.getElementById('question-text').innerHTML = q.s.replace('＿＿', `<span class="highlight-error">${q.a}</span>`);
                        const msg = new SpeechSynthesisUtterance(q.s.replace('＿＿', q.a));
                        msg.lang = 'zh-TW'; msg.rate = 0.8; window.speechSynthesis.speak(msg);
                        setTimeout(() => { currentStep++; render(); }, 3000);
                    }
                };
                optDiv.appendChild(btn);
            });
        }
        render();
    </script>
</body>
</html>
